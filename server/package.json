{
  "name": "osiris-reporting-server",
  "version": "1.0.0",
  "description": "Backend server for Osiris Reporting App",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.simple.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "migrate": "node dist/database/migrate.js",
    "smoke": "node scripts/smoke-api.mjs",
    "quality-gate": "npm run type-check && npm run smoke"
  },
  "keywords": [
    "reporting",
    "excel",
    "email",
    "dashboard"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.10",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^8.0.0",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
